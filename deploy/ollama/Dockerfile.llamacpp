# Air-gapped, OpenAI-compatible server for the SPECIFIC 2-bit (Q2_0)
# Ternary-Bonsai-8B GGUF, built on llama.cpp's llama-server.
#
# Why llama.cpp and not Ollama for Q2_0: the Q2_0 (ternary) format is not
# in mainline llama.cpp / Ollama yet. It is provided by the prism fork
# (PrismML-Eng/llama.cpp). This image pins that fork to a commit and bakes
# the checksum-verified GGUF into the final layer, so a fresh container
# serves the exact weights with zero runtime egress.
#
# Build (context = repo root, so the verify script is in scope):
#   docker build -f deploy/ollama/Dockerfile.llamacpp -t sng-bonsai-q2:local .
#
# Offline bake (no HuggingFace egress during build): pre-fetch the GGUF on a
# connected host, stage it under deploy/ollama/models/, then build with
# SNG_LLM_OFFLINE=1 (the build only verifies the staged file's SHA-256):
#   ./scripts/fetch-bonsai-gguf.sh --variant Q2_0 --out-dir deploy/ollama/models
#   docker build -f deploy/ollama/Dockerfile.llamacpp \
#     --build-arg SNG_LLM_OFFLINE=1 -t sng-bonsai-q2:local .
# This removes the multi-GB model download from the build. Stage 1 still
# compiles llama-server from the pinned prism fork (a git fetch) and pulls the
# debian base + apt packages, so a fully air-gapped build also needs those
# layers cached/pre-built or sourced from an internal mirror.
#
# Run:
#   docker run --rm -p 127.0.0.1:8081:8081 sng-bonsai-q2:local
#   curl localhost:8081/v1/models
#
# Point the control plane at it:
#   AI_LLM_ENDPOINT=http://localhost:8081/v1/chat/completions
#   AI_LLM_MODEL=Ternary-Bonsai-8B   # matches --alias below + ai.DefaultModel

# --- Stage 1: build llama-server from the pinned prism fork ---------------
FROM debian:bookworm-slim AS build
ARG LLAMACPP_REPO=https://github.com/PrismML-Eng/llama.cpp.git
# prism branch HEAD; bump deliberately and re-test when adopting new kernels.
ARG LLAMACPP_COMMIT=9b98ac8a421c556a111d9cc3e4010bc65fc08113
RUN apt-get update && apt-get install -y --no-install-recommends \
      git build-essential cmake ca-certificates libcurl4-openssl-dev \
    && rm -rf /var/lib/apt/lists/*
WORKDIR /src
RUN git init -q && git remote add origin "$LLAMACPP_REPO" \
    && git fetch --depth 1 origin "$LLAMACPP_COMMIT" \
    && git checkout -q FETCH_HEAD
# CPU-only, portable build (GGML_NATIVE=OFF avoids baking host-specific
# AVX flags into a redistributable image). Static libs => self-contained
# binary, so the runtime stage stays tiny.
RUN cmake -B build \
      -DCMAKE_BUILD_TYPE=Release \
      -DBUILD_SHARED_LIBS=OFF \
      -DGGML_NATIVE=OFF \
      -DLLAMA_CURL=ON \
      -DLLAMA_BUILD_TESTS=OFF \
      -DLLAMA_BUILD_EXAMPLES=OFF \
      -DLLAMA_BUILD_TOOLS=ON \
      -DLLAMA_BUILD_SERVER=ON \
    && cmake --build build --target llama-server -j "$(nproc)" \
    && cp build/bin/llama-server /usr/local/bin/llama-server \
    && strip /usr/local/bin/llama-server

# --- Stage 2: fetch (or verify a pre-staged) + SHA-256 verify the GGUF -----
FROM debian:bookworm-slim AS model
ARG SNG_LLM_VARIANT=Q2_0
# SNG_LLM_OFFLINE=1 bakes a GGUF pre-staged under deploy/ollama/models/ in the
# build context and verifies it without any HuggingFace download. Default 0
# downloads + verifies from HuggingFace as before. (curl below is only used by
# the default download path; the offline path needs just sha256sum + wc.)
ARG SNG_LLM_OFFLINE=0
RUN apt-get update && apt-get install -y --no-install-recommends \
      curl ca-certificates coreutils \
    && rm -rf /var/lib/apt/lists/*
WORKDIR /models
COPY scripts/fetch-bonsai-gguf.sh /usr/local/bin/fetch-bonsai-gguf.sh
# Seed any pre-staged weights from the build context. The directory always
# exists (tracked .keep); the large *.gguf are gitignored and supplied
# out-of-band for the offline bake.
COPY deploy/ollama/models/ /models/
# Online (default): downloads + verifies size + SHA-256 against the pinned
# manifest. Offline: verifies the pre-staged file only. Either way the build
# fails on a bad artifact (exit 3 on mismatch, exit 2 if offline + missing),
# so a tampered/corrupt/absent GGUF never reaches the image.
RUN chmod +x /usr/local/bin/fetch-bonsai-gguf.sh \
    && if [ "$SNG_LLM_OFFLINE" = "1" ]; then \
         /usr/local/bin/fetch-bonsai-gguf.sh --variant "$SNG_LLM_VARIANT" --out-dir /models --offline; \
       else \
         /usr/local/bin/fetch-bonsai-gguf.sh --variant "$SNG_LLM_VARIANT" --out-dir /models; \
       fi \
    && rm -f /models/.keep   # drop the git placeholder so only the GGUF ships

# --- Stage 3: minimal runtime --------------------------------------------
FROM debian:bookworm-slim AS runtime
ARG SNG_LLM_VARIANT=Q2_0
RUN apt-get update && apt-get install -y --no-install-recommends \
      libgomp1 libcurl4 ca-certificates curl \
    && rm -rf /var/lib/apt/lists/* \
    && useradd --system --uid 10001 --no-create-home --shell /usr/sbin/nologin bonsai
COPY --from=build /usr/local/bin/llama-server /usr/local/bin/llama-server
COPY --from=model /models /models
RUN chown -R 10001:10001 /models

# Served model name == ai.DefaultModel, so AI_LLM_MODEL works unchanged.
ENV SNG_LLM_ALIAS=Ternary-Bonsai-8B \
    SNG_LLM_VARIANT=${SNG_LLM_VARIANT} \
    SNG_LLM_CTX=4096 \
    SNG_LLM_PORT=8081
USER 10001
EXPOSE 8081

# llama-server exposes /health (200 only once the model is loaded) and an
# OpenAI-compatible /v1. Probe with curl (already installed) rather than a
# bash /dev/tcp bashism, so the check has no implicit shell dependency.
HEALTHCHECK --interval=15s --timeout=5s --start-period=40s --retries=10 \
  CMD curl -fsS "http://127.0.0.1:${SNG_LLM_PORT}/health" || exit 1

# Bind 0.0.0.0 inside the container; publish to loopback on the host. -ngl 0
# keeps it CPU-only. The GGUF carries its own Qwen3/ChatML chat template,
# which llama-server applies for /v1/chat/completions.
ENTRYPOINT ["/bin/sh","-c","exec llama-server \
  -m /models/Ternary-Bonsai-8B-${SNG_LLM_VARIANT}.gguf \
  --alias \"${SNG_LLM_ALIAS}\" \
  --host 0.0.0.0 --port ${SNG_LLM_PORT} \
  -c ${SNG_LLM_CTX} -ngl 0 --no-webui"]
