# ShieldNet Gateway (SNG) — Control plane environment variables.
# Copy to .env and adjust for your environment.
#
# ============================================================
# SECURITY: Never commit real secrets to this file.
# Generate fresh secrets with: openssl rand -base64 48
# ============================================================

# --- Application ---
APP_NAME=sng-control
# Allowed values: local | dev | qa | uat | prod
ENVIRONMENT=local
LOG_LEVEL=info
LOG_FORMAT=json
SERVICE_VERSION=

# --- HTTP server ---
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
HTTP_READ_TIMEOUT=15s
# Shorter than HTTP_READ_TIMEOUT so Slowloris-style header dripping
# is cut off before the request body even starts streaming.
HTTP_READ_HEADER_TIMEOUT=5s
HTTP_WRITE_TIMEOUT=30s
HTTP_SHUTDOWN_TIMEOUT=10s

# --- NATS JetStream ---
NATS_URL=nats://127.0.0.1:4222
NATS_NAME=sng-control
NATS_USER=
NATS_PASSWORD=
NATS_TOKEN=
NATS_CREDS_FILE=
NATS_TLS_CA=
NATS_TLS_CERT=
NATS_TLS_KEY=
NATS_TLS_INSECURE=false
NATS_RECONNECT_WAIT=2s
NATS_MAX_RECONNECTS=-1
# NATS_CONNECT_TIMEOUT — dial timeout for the initial TCP/TLS
# handshake against the NATS server (mapped to nats.Timeout()).
NATS_CONNECT_TIMEOUT=5s
# NATS_REQUEST_TIMEOUT — per-request deadline used for JetStream
# request-reply calls (nats.Conn.RequestWithContext, etc.). NOT used
# for the initial dial; that is NATS_CONNECT_TIMEOUT.
NATS_REQUEST_TIMEOUT=5s
NATS_PUBLISH_RETRY_ATTEMPTS=3
NATS_PUBLISH_RETRY_DELAY=200ms
NATS_DEDUP_WINDOW=2m
NATS_REPLICAS=1
# Allowed values: file | memory
NATS_STORAGE=file
NATS_FETCH_BATCH_SIZE=50
NATS_FETCH_MAX_WAIT=200ms
# Prefix prepended to every JetStream stream name. Allows multiple
# SNG control planes to share a NATS cluster without colliding.
NATS_STREAM_PREFIX=SNG

# --- PostgreSQL ---
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=sng
# Matches the POSTGRES_PASSWORD in docker-compose.yml. Override with a
# real secret when running against a managed PostgreSQL.
PG_PASSWORD=sng
PG_DATABASE=sng
# Allowed values: disable | allow | prefer | require | verify-ca | verify-full
PG_SSLMODE=disable
PG_MAX_OPEN_CONNS=20
# PG_MIN_CONNS is the **floor** on the pgxpool connection pool — the
# pool eagerly creates and maintains at least this many connections in
# the background. It is NOT the database/sql MaxIdleConns ceiling
# (pgxpool retires excess idle connections via MaxConnIdleTime instead).
# Pick a value low enough to avoid hammering Postgres at idle.
PG_MIN_CONNS=2
PG_CONN_MAX_LIFETIME=1h
PG_CONN_TIMEOUT=5s
# Runtime role adopted via SET SESSION ROLE on every new physical
# connection. Explicitly setting `PG_APP_ROLE=` (empty) disables
# the hook entirely — distinct from leaving the variable unset,
# which uses the `sng_app` default. The empty escape hatch is for
# dev environments where a single PG_USER is granted DML directly
# without role separation. Production validation rejects an empty
# value at boot (see internal/config/config.go::validate).
PG_APP_ROLE=sng_app

# --- Rate limiting (per-IP token bucket) ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RATE=30
RATE_LIMIT_BURST=60
RATE_LIMIT_CLEANUP_INTERVAL=1m
RATE_LIMIT_IDLE_TTL=10m
# Comma-separated CIDR ranges trusted to set X-Forwarded-For / X-Real-IP.
# Leave empty when no reverse proxy is in front of the service.
RATE_LIMIT_TRUSTED_PROXIES=

# --- CORS ---
CORS_ALLOWED_ORIGINS=
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-ID,X-SNG-API-Key
CORS_MAX_AGE=1h

# --- Webhook delivery ---
# Total delivery attempts (first try + retries). Must be >= 1.
# 1 = single attempt with no retries; 6 = 1 initial + 5 retries.
WEBHOOK_MAX_ATTEMPTS=6
WEBHOOK_INITIAL_DELAY=1s
WEBHOOK_MAX_DELAY=5m
WEBHOOK_DELIVERY_TIMEOUT=10s
WEBHOOK_SIGNATURE_HEADER=X-SNG-Signature
# Max pending deliveries the worker claims per tick. Larger values
# drain backlogs faster at the cost of holding more rows in
# `processing` across a worker crash. Default 32 is a balanced
# value for small-to-mid throughput tenants.
WEBHOOK_BATCH_SIZE=32
# Wait between scans of the pending queue when the previous tick
# produced no work. Shorter intervals cut delivery latency for
# bursty workloads but increase DB load at idle.
WEBHOOK_POLL_INTERVAL=1s
# Stuck-row recovery window. A row a worker claimed (`processing`)
# but never transitioned out of — typically because the worker
# crashed mid-delivery — becomes re-claimable once its
# `last_attempt_at` is older than `now - WEBHOOK_PROCESSING_TIMEOUT`.
# MUST be strictly greater than WEBHOOK_DELIVERY_TIMEOUT (validated
# at boot) to prevent the reaper from racing a genuinely in-flight
# delivery and producing a duplicate POST. Default 5m.
WEBHOOK_PROCESSING_TIMEOUT=5m

# --- Authentication ---
# HMAC key used to sign / verify operator JWTs in development. In
# production this is replaced by OIDC verification at the gateway.
# REQUIRED in prod / uat — leaving it empty there fails boot.
AUTH_JWT_SECRET=
AUTH_JWT_ISSUER=sng-control
AUTH_JWT_AUDIENCE=sng-control
AUTH_ACCESS_TOKEN_TTL=1h
# Default lifetime of a claim token (one-time device enrolment
# credential) when the API request omits `ttl_seconds`. Operators
# bumping this should also widen any SLO around "agent must be
# installed within X" — longer TTL means a stolen token has more
# window of abuse.
AUTH_CLAIM_TOKEN_TTL=24h
AUTH_API_KEY_HEADER=X-SNG-API-Key

# --- Telemetry (OpenTelemetry) ---
# OTLP/HTTP endpoint, e.g. http://otel-collector:4318. Leave empty to
# disable the OTel exporter (in-process tracing still propagates).
OTEL_EXPORTER_OTLP_ENDPOINT=
